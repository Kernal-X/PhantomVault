# Required for LLM-backed analysis and strategy generation.
# Leave blank to use deterministic fallback behavior.
OPENAI_API_KEY=

# Optional: where generated decoy files are staged.
# Defaults to C:\ProgramData\DeceptionLab\staging on Windows.
DECOY_STAGING_ROOT=

# Optional: semicolon-separated roots that interception is allowed to read from.
# Defaults include ./shared and ./demo_shared.
REAL_READ_ROOTS=

# Optional dashboard API binding.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
