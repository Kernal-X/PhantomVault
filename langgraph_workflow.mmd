    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	prepare_state(prepare_state)
	collect_events(collect_events)
	enrich_events(enrich_events)
	filter_events(filter_events)
	score_events(score_events)
	emit_alerts(emit_alerts)
